#!/usr/bin/make -f

# dpkg-buildpackage calls this via debian/rules.
# TRIPLE is passed as an environment variable by xtask.

export DH_VERBOSE = 1

%:
	dh $@

override_dh_auto_build:
ifdef TRIPLE
	. /root/.cargo/env && \
	export RUSTFLAGS="$${RUSTFLAGS:-} -L /usr/lib/$(DEB_HOST_MULTIARCH)" && \
	$(if $(ROOT_CA),export ROOT_CA=$(ROOT_CA) &&) \
	cargo zigbuild --release --target $(TRIPLE) --bin genmeta
endif

override_dh_auto_install:
ifdef TRIPLE
	mkdir -p debian/gmutils/usr/bin
	cp target/$(TRIPLE)/release/genmeta debian/gmutils/usr/bin/
	cp genmeta-ssh.sh debian/gmutils/usr/bin/
	chmod 755 debian/gmutils/usr/bin/*
endif

override_dh_auto_test:
	# skip tests in cross-compilation environment

override_dh_shlibdeps:
ifdef TRIPLE
	dh_shlibdeps -pgmutils -l/usr/lib/$(DEB_HOST_MULTIARCH)
endif

override_dh_auto_clean:
	# skip cargo clean inside container
